# Used by GoReleaser to package the pre-built `manager` binary into a
# distroless image. GoReleaser builds the binary outside Docker (via the
# `builds:` block in .goreleaser.yaml) and then runs `docker build` with a
# minimal context containing only this Dockerfile and the binary — that's why
# this file is much shorter than the top-level Dockerfile (which builds from
# source for `make docker-build`).
FROM gcr.io/distroless/static:nonroot@sha256:e3f945647ffb95b5839c07038d64f9811adf17308b9121d8a2b87b6a22a80a39
WORKDIR /
COPY manager .
USER 65532:65532
ENTRYPOINT ["/manager"]
