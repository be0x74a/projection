{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "projection chart values",
  "type": "object",
  "additionalProperties": false,
  "properties": {
    "image": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "repository": { "type": "string", "minLength": 1 },
        "tag": { "type": "string" },
        "pullPolicy": { "type": "string", "enum": ["Always", "IfNotPresent", "Never"] }
      }
    },
    "imagePullSecrets": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 }
        }
      }
    },
    "nameOverride": { "type": "string" },
    "fullnameOverride": { "type": "string" },
    "replicaCount": { "type": "integer", "minimum": 1 },
    "requeueInterval": {
      "type": "string",
      "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|µs|ms|s|m|h))+$"
    },
    "selectorWriteConcurrency": { "type": "integer", "minimum": 1 },
    "leaderElection": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "leaseDuration": {
          "type": "string",
          "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|µs|ms|s|m|h))+$"
        }
      }
    },
    "metrics": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "secure": { "type": "boolean" },
        "bindAddress": { "type": "string", "pattern": "^[^\\s]*:([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$" },
        "service": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "type": { "type": "string", "enum": ["ClusterIP", "NodePort", "LoadBalancer", "ExternalName"] },
            "port": { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        }
      }
    },
    "healthProbe": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "bindAddress": { "type": "string", "pattern": "^[^\\s]*:([1-9][0-9]{0,3}|[1-5][0-9]{4}|6[0-4][0-9]{3}|65[0-4][0-9]{2}|655[0-2][0-9]|6553[0-5])$" }
      }
    },
    "sourceMode": { "type": "string", "enum": ["allowlist", "permissive"] },
    "supportedKinds": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["apiGroup", "resources"],
        "properties": {
          "apiGroup": { "type": "string" },
          "resources": {
            "type": "array",
            "minItems": 1,
            "items": { "type": "string", "minLength": 1 }
          }
        }
      }
    },
    "resources": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "requests": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu":    { "type": "string", "pattern": "^([+-]?[0-9.]+)([eEinumkKMGTP]*[-+]?[0-9]*)$" },
            "memory": { "type": "string", "pattern": "^([+-]?[0-9.]+)([eEinumkKMGTP]*[-+]?[0-9]*)$" }
          }
        },
        "limits": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "cpu":    { "type": "string", "pattern": "^([+-]?[0-9.]+)([eEinumkKMGTP]*[-+]?[0-9]*)$" },
            "memory": { "type": "string", "pattern": "^([+-]?[0-9.]+)([eEinumkKMGTP]*[-+]?[0-9]*)$" }
          }
        }
      }
    },
    "nodeSelector":              { "type": "object" },
    "tolerations":               { "type": "array" },
    "affinity":                  { "type": "object" },
    "topologySpreadConstraints": { "type": "array" },
    "securityContext": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "pod":       { "type": "object" },
        "container": { "type": "object" }
      }
    },
    "serviceAccount": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "create":      { "type": "boolean" },
        "name":        { "type": "string" },
        "annotations": { "type": "object" }
      }
    },
    "rbac": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "aggregate": {
          "type": "boolean",
          "default": true,
          "description": "When true (default), ship the namespaced-edit and namespaced-view ClusterRoles carrying aggregation labels so the standard admin/edit roles in each namespace gain Projection CRUD and the standard view role gains read access. Set to false to suppress those two aggregated roles. The cluster-admin ClusterRole (for ClusterProjection access) is rendered unconditionally and must be bound explicitly."
        }
      }
    },
    "crds": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "install": { "type": "boolean" }
      }
    },
    "serviceMonitor": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":       { "type": "boolean" },
        "interval":      { "type": "string", "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|µs|ms|s|m|h))+$" },
        "scrapeTimeout": { "type": "string", "pattern": "^([0-9]+(\\.[0-9]+)?(ns|us|µs|ms|s|m|h))+$" },
        "labels":        { "type": "object" },
        "tlsConfig":     { "type": "object" }
      }
    },
    "networkPolicy": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled": { "type": "boolean" },
        "dns": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "namespace": { "type": "string", "minLength": 1 },
            "podLabels": { "type": "object" },
            "port":      { "type": "integer", "minimum": 1, "maximum": 65535 }
          }
        },
        "extraEgress": { "type": "array" }
      }
    },
    "podDisruptionBudget": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "enabled":        { "type": "boolean" },
        "minAvailable":   { "oneOf": [ { "type": "integer", "minimum": 0 }, { "type": "string", "pattern": "^(100|[1-9]?[0-9])%$" }, { "type": "null" } ] },
        "maxUnavailable": { "oneOf": [ { "type": "integer", "minimum": 0 }, { "type": "string", "pattern": "^(100|[1-9]?[0-9])%$" }, { "type": "null" } ] }
      }
    }
  }
}
